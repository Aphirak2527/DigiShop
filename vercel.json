{
  "installCommand": "npm install -g pnpm@8 && pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm --filter @workspace/premshop run build",
  "outputDirectory": "artifacts/premshop/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
